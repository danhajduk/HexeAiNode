{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hexe.local/schemas/client-ai/prompt-state.response.schema.json",
  "title": "Prompt State Response",
  "description": "Response payload for GET /api/prompts/services and write operations that return prompt state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "configured",
    "state",
    "summary"
  ],
  "properties": {
    "configured": {
      "type": "boolean",
      "const": true
    },
    "state": {
      "$ref": "../prompt-service-state.schema.json"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_count",
        "review_due_count",
        "active_count"
      ],
      "properties": {
        "prompt_count": {
          "type": "integer",
          "minimum": 0
        },
        "review_due_count": {
          "type": "integer",
          "minimum": 0
        },
        "active_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
